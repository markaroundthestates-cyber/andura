{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "checkJs": true
  },
  "include": [
    "src/util/**/*.js",
    "src/migrations/**/*.js",
    "src/storage/**/*.js",
    "src/engine/*.js",
    "src/engine/bayesianNutrition/**/*.js",
    "src/engine/tempo/**/*.js",
    "src/global.d.ts",
    "src/db.d.ts",
    "src/constants.d.ts"
  ],
  "exclude": [
    "src/util/__tests__/**",
    "src/util/tests/**",
    "src/migrations/__tests__/**",
    "src/migrations/tests/**",
    "src/storage/__tests__/**",
    "src/storage/tests/**",
    "src/engine/__tests__/**",
    "src/engine/tests/**",
    "src/engine/bayesianNutrition/__tests__/**",
    "src/engine/bayesianNutrition/tests/**",
    "src/engine/tempo/__tests__/**",
    "src/engine/tempo/tests/**"
  ]
}

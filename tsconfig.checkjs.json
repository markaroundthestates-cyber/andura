{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "checkJs": true
  },
  "include": [
    "src/util/**/*.js",
    "src/migrations/**/*.js",
    "src/storage/**/*.js",
    "src/engine/calibration.js",
    "src/engine/calibrationReconciliation.js",
    "src/global.d.ts",
    "src/db.d.ts",
    "src/constants.d.ts"
  ],
  "exclude": [
    "src/util/__tests__/**",
    "src/util/tests/**",
    "src/migrations/__tests__/**",
    "src/migrations/tests/**",
    "src/storage/__tests__/**",
    "src/storage/tests/**"
  ]
}

ead","[[VAULT_RULES#ANTI_RECURRENCE_RULES]] §AR.1-§AR.19 preserved unchanged","[[04-architecture/_sources/karpathy-llm-wiki-gist-apr-2026]] immutable raw source","[[📥_inbox/PROMPT_CC_FAZA_3_KARPATHY_OPTION_B]] §1-§7 Daniel execute spec"],"amendments":[{"date":"2026-05-11","note":"FAZA 3 Phase 2 — Karpathy real rewrite Option B + voice preservation policy §1 MANDATORY per wiki page + 3 operations adapted Andura cu wiki/ pure folder authority"}]},"task_lines":[],"tasks":{},"codeblock_ranges":[[88,102],[125,158],[191,208],[212,223],[227,239],[243,253],[257,264]],"key":"CLAUDE.md"},

9,0.0216883,0.05190497,0.01372432,-0.00408978,-0.06482068,0.03576578,-0.03959329,0.22846404,-0.00530022,-0.01915138,0.09225926,-0.00197103,0.01892432,0.0975831,0.05302198,-0.00682997,0.07771905,0.10140532,-0.00848498,-0.00495879,0.02050891,-0.01331815,0.00142118,-0.00479372,-0.01430761,0.01122046,0.03590013,-0.03022587,-0.00829518,0.05690306,-0.0837969,-0.03751802,0.00164039,0.02882778,0.05025071,-0.03331465,-0.00469658,-0.01898477,-0.00762009,0.03035674,0.0181317,-0.00637821,0.01255302,0.00106139,-0.02427687,-0.03476208,-0.07668334,0.04778995,0.10253035,-0.00956522],"last_embed":{"tokens":467,"hash":"ku22eq"}}},"last_read":{"hash":"ku22eq","at":1778532242538},"class_name":"SmartSource","last_import":{"mtime":1777145514131,"size":4200,"at":1778531809298,"hash":"ku22eq"},"blocks":{"#🌈Colorette":[1,135],"#🌈Colorette#{1}":[3,4],"#🌈Colorette#{2}":[5,5],"#🌈Colorette#{3}":[6,6],"#🌈Colorette#{4}":[7,7],"#🌈Colorette#{5}":[8,8],"#🌈Colorette#{6}":[9,9],"#🌈Colorette#{7}":[10,11],"#🌈Colorette#{8}":[12,13],"#🌈Colorette#Quickstart":[14,52],"#🌈Colorette#Quickstart#{1}":[16,52],"#🌈Colorette#Installation":[53,58],"#🌈Colorette#Installation#{1}":[55,58],"#🌈Colorette#API":[59,84],"#🌈Colorette#API#\\<color\\>()":[61,70],"#🌈Colorette#API#\\<color\\>()#{1}":[63,70],"#🌈Colorette#API#createColors()":[71,80],"#🌈Colorette#API#createColors()#{1}":[73,80],"#🌈Colorette#API#isColorSupported":[81,84],"#🌈Colorette#API#isColorSupported#{1}":[83,84],"#🌈Colorette#Environment":[85,98],"#🌈Colorette#Environment#{1}":[87,98],"#🌈Colorette#Supported colors":[99,112],"#🌈Colorette#Supported colors#{1}":[101,112],"#🌈Colorette#[Benchmarks](https://github.com/jorgebucaran/colorette/actions/workflows/bench.yml)":[113,127],"#🌈Colorette#[Benchmarks](https://github.com/jorgebucaran/colorette/actions/workflows/bench.yml)#{1}":[115,127],"#🌈Colorette#Acknowledgments":[128,131],"#🌈Colorette#Acknowledgments#{1}":[130,131],"#🌈Colorette#License":[132,135],"#🌈Colorette#License#{1}":[134,135]},"outlinks":[{"title":"2x faster","target":"#benchmarks","line":7},{"title":"`NO_COLOR`","target":"https://no-color.org","line":9},{"title":"**Upgrading from Colorette `1.x`?**","target":"https://github.com/jorgebucaran/colorette/issues/70","line":12},{"title":"template literals","target":"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Template_literals","line":26},{"title":"supported colors","target":"#supported-colors","line":63},{"title":"34mI'm blue\\x1b[39m\n```\n\n### createColors()\n\nOverride terminal color detection via `createColors({ useColor })`.\n\n```js\nimport { createColors } from \"colorette\"\n\nconst { blue } = createColors({ useColor: false })\n```\n\n### isColorSupported\n\n`true` if your terminal supports color, `false` otherwise. Used internally, but exposed for convenience.\n\n## Environment\n\nYou can override color detection from the CLI by setting the `--no-color` or `--color` flags.\n\n```console\n$ ./example.js --no-color | ./consumer.js\n```\n\nOr if you can't use CLI flags, by setting the `NO_COLOR=` or `FORCE_COLOR=` environment variables.\n\n```console\n$ NO_COLOR= ./example.js | ./consumer.js\n```\n\n## Supported colors\n\n| Colors  | Background Colors | Bright Colors | Bright Background Colors | Modifiers         |\n| ------- | ----------------- | ------------- | ------------------------ | ----------------- |\n| black   | bgBlack           | blackBright   | bgBlackBright            | dim               |\n| red     | bgRed             | redBright     | bgRedBright              | **bold**          |\n| green   | bgGreen           | greenBright   | bgGreenBright            | hidden            |\n| yellow  | bgYellow          | yellowBright  | bgYellowBright           | _italic_          |\n| blue    | bgBlue            | blueBright    | bgBlueBright             | <u>underline</u>  |\n| magenta | bgMagenta         | magentaBright | bgMagentaBright          | ~~strikethrough~~ |\n| cyan    | bgCyan            | cyanBright    | bgCyanBright             | reset             |\n| white   | bgWhite           | whiteBright   | bgWhiteBright            |                   |\n| gray    |                   |               |                          |                   |\n\n## [Benchmarks","target":"https://github.com/jorgebucaran/colorette/actions/workflows/bench.yml","line":68},{"title":"@alexeyraspopov","target":"https://github.com/alexeyraspopov","line":130},{"title":"picocolors","target":"https://github.com/alexeyraspopov/picocolors","line":130},{"title":"Chalk","target":"https://github.com/chalk/chalk","line":130},{"title":"@jorgebucaran","target":"https://github.com/jorgebucaran","line":130},{"title":"Clor","target":"https://github.com/jorgebucaran/colorette/commit/b01b5b9961ceb7df878583a3002e836fae9e37ce","line":130},{"title":"@Qix-","target":"https://github.com/Qix-","line":130},{"title":"@sindresorhus","target":"https://github.com/sindresorhus","line":130},{"title":"MIT","target":"LICENSE.md","line":134}],"task_lines":[],"tasks":{},"codeblock_ranges":[[16,24],[28,35],[39,41],[45,51],[55,57],[65,69],[75,79],[89,91],[95,97],[115,117],[119,126]],"key":"node_modules/colorette/README.md"},

    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/ui": "^4.1.5",
    "gh-pages": "^6.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "vite": "^5.2.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@sentry/browser": "^10.49.0"
  }
}

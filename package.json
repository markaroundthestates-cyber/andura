{
  "name": "andura",
  "version": "2.0.0",
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20 <26"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test tests/smoke.spec.js",
    "test:unit": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:smoke": "playwright test tests/e2e/smoke",
    "test:all": "npm run test:run && npm run test:e2e",
    "simulation:a": "node --experimental-vm-modules tests/simulation/sequential-load.js",
    "simulation:b": "node --experimental-vm-modules tests/simulation/property-based.js",
    "simulation:c": "playwright test tests/simulation/parallel-fuzz.spec.js",
    "test:calibration": "node --experimental-vm-modules tests/simulation/calibration-test.js",
    "golden-master": "node tests/golden-master/runner.js",
    "golden-master:dry-run": "node tests/golden-master/runner.js --dry-run",
    "golden-master:generate": "node tests/golden-master/profiles/generate.js",
    "mutation": "npx stryker run --configFile tests/golden-master/mutation/stryker.conf.js",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "eslint . --max-warnings=9999",
    "lint:fix": "eslint . --fix --max-warnings=9999",
    "lighthouse": "lhci autorun",
    "lighthouse:live": "lhci autorun --collect.url=https://andura.app",
    "visual:update": "playwright test visual-regression --update-snapshots",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "depcheck": "depcheck --ignores='husky,lint-staged,@stryker-mutator/*,@lhci/cli,size-limit,@size-limit/preset-app,depcheck,madge,jscpd,license-checker,@axe-core/playwright,@nearform/playwright-firebase,fast-check'",
    "madge:circular": "madge --circular --extensions js,ts,tsx,jsx src/",
    "jscpd": "jscpd src/",
    "licenses": "license-checker --production --summary"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.18.0",
    "@lhci/cli": "^0.15.1",
    "@nearform/playwright-firebase": "^1.2.9",
    "@playwright/test": "^1.59.1",
    "@size-limit/preset-app": "^12.1.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/eslint": "^9.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.5.0",
    "depcheck": "^1.4.7",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.8.0",
    "firebase-admin": "^13.10.0",
    "gh-pages": "^6.1.1",
    "husky": "^9.1.7",
    "jscpd": "^4.2.3",
    "jsdom": "^25.0.1",
    "license-checker": "^25.0.1",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "postcss": "^8.5.14",
    "size-limit": "^12.1.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^5.2.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.4",
    "workbox-window": "^7.4.1"
  },
  "dependencies": {
    "@sentry/browser": "^10.49.0",
    "dexie": "^4.4.2",
    "lucide-react": "^1.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.13"
  }
}

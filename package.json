{
  "name": "andura",
  "version": "2.0.0",
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20 <26"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test tests/smoke-react.spec.ts",
    "test:unit": "vitest",
    "test:run": "vitest run --exclude '**/_engine_golden.harness.test.js'",
    "test:golden": "vitest run tests/engine/_engine_golden.harness.test.js",
    "test:engine": "vitest run tests/engine/",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/smoke-react.spec.ts tests/magic-link.spec.ts",
    "test:visual": "playwright test tests/visual-regression.spec.ts",
    "test:all": "npm run test:run && npm run test:e2e",
    "mutation:engine": "stryker run tests/golden-master/mutation/stryker.engine.conf.js",
    "exploration": "node scripts/nightly-exploration.mjs",
    "coach:replay": "vitest run scripts/coach-replay/cli.test.mjs",
    "simulation:c": "playwright test tests/simulation/parallel-fuzz.spec.js",
    "test:calibration": "node --experimental-vm-modules tests/simulation/calibration-test.js",
    "golden-master": "node tests/golden-master/runner.js",
    "golden-master:dry-run": "node tests/golden-master/runner.js --dry-run",
    "golden-master:generate": "node tests/golden-master/profiles/generate.js",
    "mutation": "npx stryker run --configFile tests/golden-master/mutation/stryker.conf.js",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "typecheck:strict-js": "tsc --noEmit --project tsconfig.checkjs.json",
    "lint": "eslint . --max-warnings=9999",
    "lint:fix": "eslint . --fix --max-warnings=9999",
    "lighthouse": "lhci autorun",
    "lighthouse:live": "lhci autorun --collect.url=https://andura.app",
    "healthcheck": "node scripts/healthcheck.cjs",
    "firebase:deploy:rules": "node scripts/deploy-rules.cjs",
    "firebase:deploy:rules:dry": "node scripts/deploy-rules.cjs --dry-run",
    "test-restore": "node scripts/test-restore.cjs",
    "test-restore:dry": "node scripts/test-restore.cjs --dry-run",
    "visual:update": "playwright test visual-regression --update-snapshots",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "depcheck": "depcheck --ignores='husky,lint-staged,@stryker-mutator/*,@lhci/cli,size-limit,@size-limit/preset-app,depcheck,madge,jscpd,license-checker,@axe-core/playwright,@nearform/playwright-firebase,fast-check,@eslint/js,@types/eslint,@vitest/coverage-v8,autoprefixer,postcss,tailwindcss,@fontsource-variable/inter,@fontsource-variable/manrope,@fontsource-variable/space-grotesk,@fontsource/space-mono,firebase-tools,virtual:pwa-register,playwright'",
    "madge:circular": "madge --circular --extensions js,ts,tsx,jsx --exclude \"pages/coach|pages/settings|ui/nav\" src/",
    "jscpd": "jscpd src/",
    "licenses": "license-checker --production --summary"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@browserbasehq/stagehand": "^3.5.0",
    "@eslint/js": "^9.18.0",
    "@lhci/cli": "^0.15.1",
    "@nearform/playwright-firebase": "^1.2.9",
    "@playwright/test": "^1.60.0",
    "@size-limit/preset-app": "^12.1.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/eslint": "^9.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.5.0",
    "checkly": "^7.15.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.5.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.8.0",
    "firebase-admin": "^13.10.0",
    "firebase-tools": "^15.20.0",
    "gh-pages": "^6.1.1",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "jscpd": "^4.2.3",
    "jsdom": "^25.0.1",
    "license-checker": "^25.0.1",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "postcss": "^8.5.15",
    "sharp": "^0.35.1",
    "size-limit": "^12.1.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^5.2.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.4",
    "workbox-window": "^7.4.1",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/space-mono": "^5.2.9",
    "@sentry/browser": "10.57.0",
    "dexie": "^4.4.3",
    "firebase": "^12.14.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.14"
  }
}

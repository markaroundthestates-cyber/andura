# §18-H3 audit fix — env var template for build-time injection (Vite).
# Copy to `.env.local` (gitignored) and fill in real values.
# Per §4-C2 + §4-H4 + §4-H5 audit migrations to env-var pattern.

# Firebase Web API Key — per Firebase docs PUBLIC-SAFE (NOT a secret).
# Source: Firebase Console → Project Settings → Web API Key.
# Fallback chain: VITE_FIREBASE_API_KEY → window.__FIREBASE_API_KEY → PLACEHOLDER_WEB_API_KEY.
VITE_FIREBASE_API_KEY=

# Firebase Realtime Database URL (region-specific).
# Default fallback: europe-west1 project URL hardcoded in src/firebase.js.
VITE_FIREBASE_RTDB_URL=https://fittracker-c34e8-default-rtdb.europe-west1.firebasedatabase.app

# Sentry DSN for production error tracking.
# Default fallback: project DSN hardcoded in src/util/sentry.js.
VITE_SENTRY_DSN=

# Application version (release tagging in Sentry).
VITE_APP_VERSION=2.0.0

# Track 7 §7.6-activate — CI/local install consistency.
# legacy-peer-deps required pentru madge@8 peerOptional typescript ^5.4.4 vs
# project typescript ^6.0.3 (madge CLI tool only, peer optional, doesn't affect
# runtime). Daniel decision: keep typescript ^6.0.3 (newer), accept legacy-peer-deps
# pentru madge install.
#
# Without this file, `npm ci` în GitHub Actions defaults la strict peer resolution
# → fails on madge peer conflict → entire validate job exit 1.
legacy-peer-deps=true
